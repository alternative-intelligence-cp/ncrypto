use "stdlib/core.npk".*;
use "src/util/hex.npk".*;
use "src/kdf/argon2.npk".*;

pub func:failsafe = int32(tbb32:err) { exit(1i32); };

func:test_argon2id = int32() {
    int64:pwd_ptr = cast_unchecked<int64>("password");
    int64:salt_ptr = cast_unchecked<int64>("somesalt");
    
    int64:out_ptr = cast_unchecked<int64>(alloc(32i64));
    
    // t_cost=3, m_cost=256, lanes=1
    drop raw argon2id_hash(pwd_ptr, 8i64, salt_ptr, 8i64, out_ptr, 32i64, 3i64, 256i64, 1i64);
    
    int64:exp_ptr = cast_unchecked<int64>(alloc(32i64));
    drop raw hex_to_raw("aff8d0a36038af7b01bff39a89fda54652f67da404f7da8776324f4a2931d794", exp_ptr);
    
    int64->:OUT = cast_unchecked<int64->>(out_ptr);
    int64->:EXP = cast_unchecked<int64->>(exp_ptr);
    
    int64:i = 0i64;
    while (i < 32i64) {
        int64:wi = i / 8i64;
        int64:sh = (i & 7i64) * 8i64;
        int64:out_byte = (OUT[wi] >> sh) & 255i64;
        int64:exp_byte = (EXP[wi] >> sh) & 255i64;
        if (out_byte != exp_byte) { fail(1i32); }
        i += 1i64;
    }
    
    pass 0i32;
};

pub func:main = int32() {
    int32:r1 = raw test_argon2id();
    if (r1 != 0i32) { exit(1i32); }
    
    drop sys!!(1i64, 1i64, "All Argon2 tests passed!\n", 25i64);
    exit(0i32);
};
