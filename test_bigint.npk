// test_bigint.npk
use "stdlib/core.npk".*;
use "src/math/bigint.npk".*;

pub func:failsafe = int32(tbb32:err) { exit(1i32); };

pub func:assert_eq = int32(int64:actual, int64:expected, string:name) {
    int64->:A = cast_unchecked<int64->>(actual);
    int64->:E = cast_unchecked<int64->>(expected);
    
    if (A[1i64] != E[1i64]) {
        drop sys!!(1i64, 1i64, "FAIL LEN: ", 10i64);
        drop sys!!(1i64, 1i64, name, 64i64);
        drop sys!!(1i64, 1i64, "\n", 1i64);
        pass 1i32;
    }
    if (A[2i64] != E[2i64]) {
        drop sys!!(1i64, 1i64, "FAIL SIGN: ", 11i64);
        drop sys!!(1i64, 1i64, name, 64i64);
        drop sys!!(1i64, 1i64, "\n", 1i64);
        pass 1i32;
    }
    int64:i = 0i64;
    int64:len = A[1i64];
    while (i < len) {
        if (A[3i64 + i] != E[3i64 + i]) {
            drop sys!!(1i64, 1i64, "FAIL LIMB: ", 11i64);
            drop sys!!(1i64, 1i64, name, 64i64);
            drop sys!!(1i64, 1i64, "\n", 1i64);
            pass 1i32;
        }
        i += 1i64;
    }
    pass 0i32;
};

