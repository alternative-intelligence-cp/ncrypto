use "src/sha1.npk".*;

pub func:main = int32() {
    string:h1 = raw sha1("hello world");
    string:h2 = raw sha1("");
    string:h3 = raw sha1("The quick brown fox jumps over the lazy dog");

    if (h1 != "2aae6c35c94fcfb415dbe95f408b9ce91ee846ed") {
        drop sys!!(1i64, 1i64, raw string_data_ptr("h1 wrong\n"), 9i64);
        exit(1i32);
    }

    if (h2 != "da39a3ee5e6b4b0d3255bfef95601890afd80709") {
        drop sys!!(1i64, 1i64, raw string_data_ptr("h2 wrong\n"), 9i64);
        exit(2i32);
    }

    if (h3 != "2fd4e1c67a2d28fced849ee1bb76e7391b93eb12") {
        drop sys!!(1i64, 1i64, raw string_data_ptr("h3 wrong\n"), 9i64);
        exit(3i32);
    }

    drop sys!!(1i64, 1i64, raw string_data_ptr("OK!\n"), 4i64);
    exit(0i32);
};

func:failsafe = int32(tbb32:err) {
    exit(1i32);
};
