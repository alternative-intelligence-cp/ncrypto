// test_ecdsa.npk
use "stdlib/core.npk".*;
use "src/asymmetric/ecc.npk".*;
use "src/asymmetric/ecdsa.npk".*;
use "src/math/bigint.npk".*;
use "src/util/hex.npk".*;

pub func:failsafe = int32(tbb32:err) { exit(1i32); };

pub func:main = int32() {
    drop sys!!(1i64, 1i64, "Testing ECDSA Secp256k1...\n", 27i64);
    
    Secp256k1Params:params = raw secp256k1_get_params();
    
    drop sys!!(1i64, 1i64, "1. Generate private key d\n", 26i64);
    // 1. Generate a random private key d in [1, n-1]
    int64:d = raw bigint_from_random(params.n);
    
    drop sys!!(1i64, 1i64, "2. Generate public key Q\n", 25i64);
    // 2. Generate public key Q = d * G
    ECCPoint:Q = raw ecc_point_alloc();
    drop raw ecc_scalar_mul_ct(d, params.G, params.p, Q);
    
    // 3. Message hash z
    int64:z = raw ecc_bigint_from_hex("4B68568BCA2A052DF56D380026A74C402ECA9E62C4E5E01FA5920C17E4513E0E");
    
    drop sys!!(1i64, 1i64, "4. Sign\n", 8i64);
    // 4. Sign
    ECDSASignature:sig = raw ecdsa_signature_alloc();
    drop raw ecdsa_sign(z, d, params, sig);
    
    drop sys!!(1i64, 1i64, "Signed successfully.\n", 21i64);
    
    drop sys!!(1i64, 1i64, "5. Verify (valid)\n", 18i64);
    // 5. Verify (valid)
    int32:valid = raw ecdsa_verify(z, Q, params, sig);
    if (valid != 1i32) {
        drop sys!!(1i64, 1i64, "Error: Valid signature rejected!\n", 33i64);
        exit(1i32);
    }
    drop sys!!(1i64, 1i64, "Verification passed (valid).\n", 29i64);
    
    // 6. Verify (invalid)
    int64:z_bad = raw ecc_bigint_from_hex("4B68568BCA2A052DF56D380026A74C402ECA9E62C4E5E01FA5920C17E4513E0F");
    int32:valid_bad = raw ecdsa_verify(z_bad, Q, params, sig);
    if (valid_bad == 1i32) {
        drop sys!!(1i64, 1i64, "Error: Invalid signature accepted!\n", 35i64);
        exit(1i32);
    }
    drop sys!!(1i64, 1i64, "Verification failed correctly (invalid).\n", 41i64);
    
    drop raw bigint_free(d);
    drop raw ecc_point_free(Q);
    drop raw bigint_free(z);
    drop raw bigint_free(z_bad);
    drop raw ecdsa_signature_free(sig);
    drop raw secp256k1_free_params(params);
    
    drop sys!!(1i64, 1i64, "All ECDSA tests passed!\n", 24i64);
    exit(0i32);
};
