func:sha512_transform = int32(int64:state_ptr, int64->:block, int64:block_off) {
    int64->:state = cast_unchecked<int64->>(state_ptr);

    int64:w_ptr_raw = cast_unchecked<int64>(alloc(1024i64)); // 80 * 8 bytes
    int64->:w = cast_unchecked<int64->>(w_ptr_raw);

    int64:i = 0i64;
    while (i < 16i64) {
        uint64:val = raw buf_get_u64_be(block, block_off + i * 8i64);
        w[i] = cast_unchecked<int64>(val);
        i += 1i64;
    }

    while (i < 80i64) {
        uint64:wi15 = cast_unchecked<uint64>(w[i - 15i64]);
        uint64:wi2 = cast_unchecked<uint64>(w[i - 2i64]);
        uint64:wi16 = cast_unchecked<uint64>(w[i - 16i64]);
        uint64:wi7 = cast_unchecked<uint64>(w[i - 7i64]);
        
        uint64:s0 = raw sha512_sig0(wi15);
        uint64:s1 = raw sha512_sig1(wi2);
        w[i] = cast_unchecked<int64>(wi16 + s0 + wi7 + s1);
        i += 1i64;
    }

    uint64:a = raw buf_get_u64_be(state, 0i64);
    uint64:b = raw buf_get_u64_be(state, 8i64);
    uint64:c = raw buf_get_u64_be(state, 16i64);
    uint64:d = raw buf_get_u64_be(state, 24i64);
    uint64:e = raw buf_get_u64_be(state, 32i64);
    uint64:f = raw buf_get_u64_be(state, 40i64);
    uint64:g = raw buf_get_u64_be(state, 48i64);
    uint64:h = raw buf_get_u64_be(state, 56i64);

    i = 0i64;
    while (i < 80i64) {
        uint64:ep1 = raw sha512_ep1(e);
        uint64:ch = raw sha512_ch(e, f, g);
        uint64:k_val = raw sha512_k(i);
        uint64:wi = cast_unchecked<uint64>(w[i]);
        uint64:t1 = h + ep1 + ch + k_val + wi;
        
        uint64:ep0 = raw sha512_ep0(a);
        uint64:maj = raw sha512_maj(a, b, c);
        uint64:t2 = ep0 + maj;

        h = g;
        g = f;
        f = e;
        e = d + t1;
        d = c;
        c = b;
        b = a;
        a = t1 + t2;

        i += 1i64;
    }

    uint64:sa = raw buf_get_u64_be(state, 0i64);
    uint64:sb = raw buf_get_u64_be(state, 8i64);
    uint64:sc = raw buf_get_u64_be(state, 16i64);
    uint64:sd = raw buf_get_u64_be(state, 24i64);
    uint64:se = raw buf_get_u64_be(state, 32i64);
    uint64:sf = raw buf_get_u64_be(state, 40i64);
    uint64:sg = raw buf_get_u64_be(state, 48i64);
    uint64:sh = raw buf_get_u64_be(state, 56i64);

    drop raw buf_set_u64_be(state, 0i64, sa + a);
    drop raw buf_set_u64_be(state, 8i64, sb + b);
    drop raw buf_set_u64_be(state, 16i64, sc + c);
    drop raw buf_set_u64_be(state, 24i64, sd + d);
    drop raw buf_set_u64_be(state, 32i64, se + e);
    drop raw buf_set_u64_be(state, 40i64, sf + f);
    drop raw buf_set_u64_be(state, 48i64, sg + g);
    drop raw buf_set_u64_be(state, 56i64, sh + h);

    drop dalloc(cast_unchecked<int8->>(w_ptr_raw));
    pass 0i32;
};

pub func:sha512_init = int64() {
    int64:ctx = cast_unchecked<int64>(alloc(224i64)); 
    int64->:ctx_64 = cast_unchecked<int64->>(ctx);
    drop raw buf_set_u64_be(ctx_64, 0i64, 7640891576956012808u64);
    drop raw buf_set_u64_be(ctx_64, 8i64, 13503953896175478587u64);
    drop raw buf_set_u64_be(ctx_64, 16i64, 4354685564936845355u64);
    drop raw buf_set_u64_be(ctx_64, 24i64, 11912009170470909681u64);
    drop raw buf_set_u64_be(ctx_64, 32i64, 5840696475078001361u64);
    drop raw buf_set_u64_be(ctx_64, 40i64, 11170449401992604703u64);
    drop raw buf_set_u64_be(ctx_64, 48i64, 2270897969802886507u64);
    drop raw buf_set_u64_be(ctx_64, 56i64, 6620516959819538809u64);
    
    drop raw buf_set_u64_be(ctx_64, 64i64, 0u64); // count high
    drop raw buf_set_u64_be(ctx_64, 72i64, 0u64); // count low
    ctx_64[10i64] = 0i64; // buflen at offset 80
    ctx_64[27i64] = 0i64; // is384 at offset 216
    pass ctx;
};

pub func:sha384_init = int64() {
    int64:ctx = cast_unchecked<int64>(alloc(224i64)); 
    int64->:ctx_64 = cast_unchecked<int64->>(ctx);
    drop raw buf_set_u64_be(ctx_64, 0i64, 14680500436340154072u64);
    drop raw buf_set_u64_be(ctx_64, 8i64, 7105036623409894663u64);
    drop raw buf_set_u64_be(ctx_64, 16i64, 10473403895298186519u64);
    drop raw buf_set_u64_be(ctx_64, 24i64, 1526699215303891257u64);
    drop raw buf_set_u64_be(ctx_64, 32i64, 7436329637833083697u64);
    drop raw buf_set_u64_be(ctx_64, 40i64, 10282925794625328401u64);
    drop raw buf_set_u64_be(ctx_64, 48i64, 15784041429090275239u64);
    drop raw buf_set_u64_be(ctx_64, 56i64, 5167115440072839076u64);
    
    drop raw buf_set_u64_be(ctx_64, 64i64, 0u64); // count high
    drop raw buf_set_u64_be(ctx_64, 72i64, 0u64); // count low
    ctx_64[10i64] = 0i64; // buflen at offset 80
    ctx_64[27i64] = 1i64; // is384 at offset 216
    pass ctx;
};

pub func:sha512_update = int32(int64:ctx, int64:buf_ptr, int64:length) {
    if (ctx == 0i64) { pass -1i32; }
    if (buf_ptr == 0i64) { pass -1i32; }
    if (length == 0i64) { pass 0i32; } 

    int64->:ctx_64 = cast_unchecked<int64->>(ctx);
    
    uint64:len_bits = cast_unchecked<uint64>(length * 8i64);
    uint64:clow = raw buf_get_u64_be(ctx_64, 72i64);
    uint64:chigh = raw buf_get_u64_be(ctx_64, 64i64);
    
    uint64:new_clow = clow + len_bits;
    if (new_clow < clow) {
        chigh = chigh + 1u64;
    }
    
    drop raw buf_set_u64_be(ctx_64, 72i64, new_clow);
    drop raw buf_set_u64_be(ctx_64, 64i64, chigh);
    
    int64:buflen = ctx_64[10i64];
    int64:i = 0i64;

    if (buflen > 0i64) {
        int64:need = 128i64 - buflen;
        int64:copy = length;
        if (length >= need) { copy = need; }

        drop raw local_memcpy(ctx_64, 88i64 + buflen, buf_ptr, copy);
        buflen += copy;
        ctx_64[10i64] = buflen;
        i += copy;

        if (buflen == 128i64) {
            drop raw sha512_transform(ctx, ctx_64, 88i64);
            ctx_64[10i64] = 0i64;
        }
    }

    int64->:src_buf = cast_unchecked<int64->>(buf_ptr);
    while ((i + 128i64) <= length) {
        drop raw sha512_transform(ctx, src_buf, i);
        i += 128i64;
    }

    if (i < length) {
        int64:rem = length - i;
        ctx_64[10i64] = rem;
        int64:src_ptr = buf_ptr + i;
        drop raw local_memcpy(ctx_64, 88i64, src_ptr, rem);
    }
    
    pass 0i32;
};

pub func:sha512_finalize = string(int64:ctx) {
    if (ctx == 0i64) { pass ""; }
    int64->:ctx_64 = cast_unchecked<int64->>(ctx);

    int64:fbuf = cast_unchecked<int64>(alloc(256i64));
    int64->:fbuf_64 = cast_unchecked<int64->>(fbuf);
    
    int64:rem = ctx_64[10i64];
    int64->:s_buf = cast_unchecked<int64->>(ctx + 88i64);
    drop raw local_memcpy(fbuf_64, 0i64, ctx + 88i64, rem);
    drop raw buf_set_u8(fbuf_64, rem, 128i64); // 0x80
    rem += 1i64;

    if (rem > 112i64) {
        drop raw local_memset(fbuf_64, rem, 0i64, 128i64 - rem);
        drop raw sha512_transform(ctx, fbuf_64, 0i64);
        rem = 0i64;
    }

    drop raw local_memset(fbuf_64, rem, 0i64, 112i64 - rem);

    uint64:chigh = raw buf_get_u64_be(ctx_64, 64i64);
    uint64:clow = raw buf_get_u64_be(ctx_64, 72i64);
    
    drop raw buf_set_u64_be(fbuf_64, 112i64, chigh);
    drop raw buf_set_u64_be(fbuf_64, 120i64, clow);

    drop raw sha512_transform(ctx, fbuf_64, 0i64);

    int64:is384 = ctx_64[27i64];
    int64:words_to_output = 8i64;
    if (is384 == 1i64) {
        words_to_output = 6i64;
    }

    string:out_hex = "";
    int64:n = 0i64;
    while (n < words_to_output) {
        uint64:val = raw buf_get_u64_be(ctx_64, n * 8i64);
        int64:v = cast_unchecked<int64>(val);
        int64:b0 = (v >> 56i64) & 255i64;
        int64:b1 = (v >> 48i64) & 255i64;
        int64:b2 = (v >> 40i64) & 255i64;
        int64:b3 = (v >> 32i64) & 255i64;
        int64:b4 = (v >> 24i64) & 255i64;
        int64:b5 = (v >> 16i64) & 255i64;
        int64:b6 = (v >> 8i64) & 255i64;
        int64:b7 = v & 255i64;
        
        string:h0 = string_to_hex(string_from_char(cast_unchecked<int8>(b0)));
        string:h1 = string_to_hex(string_from_char(cast_unchecked<int8>(b1)));
        string:h2 = string_to_hex(string_from_char(cast_unchecked<int8>(b2)));
        string:h3 = string_to_hex(string_from_char(cast_unchecked<int8>(b3)));
        string:h4 = string_to_hex(string_from_char(cast_unchecked<int8>(b4)));
        string:h5 = string_to_hex(string_from_char(cast_unchecked<int8>(b5)));
        string:h6 = string_to_hex(string_from_char(cast_unchecked<int8>(b6)));
        string:h7 = string_to_hex(string_from_char(cast_unchecked<int8>(b7)));
        
        out_hex = out_hex + h0 + h1 + h2 + h3 + h4 + h5 + h6 + h7;
        n += 1i64;
    }

    drop dalloc(cast_unchecked<int8->>(fbuf));
    pass out_hex;
};

pub func:sha512_free = int32(int64:ctx) {
    if (ctx != 0i64) {
        drop dalloc(cast_unchecked<int8->>(ctx));
    }
    pass 0i32;
};

pub func:sha512 = string(string:data) {
    int64:ctx = raw sha512_init();
    int64:data_ptr = raw string_data_ptr(data);
    int64:data_len = string_length(data);
    drop raw sha512_update(ctx, data_ptr, data_len);
    string:res = raw sha512_finalize(ctx);
    drop raw sha512_free(ctx);
    pass res;
};

pub func:sha384 = string(string:data) {
    int64:ctx = raw sha384_init();
    int64:data_ptr = raw string_data_ptr(data);
    int64:data_len = string_length(data);
    drop raw sha512_update(ctx, data_ptr, data_len);
    string:res = raw sha512_finalize(ctx);
    drop raw sha512_free(ctx);
    pass res;
};
