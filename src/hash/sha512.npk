// sha512.npk - Native SHA-512 and SHA-384 Implementation

pub func:string_data_ptr = int64(string:s) {
    int64->:p_struct = cast_unchecked<int64->>(@s);
    int64:struct_addr = <-p_struct;
    int64->:struct_ptr = cast_unchecked<int64->>(struct_addr);
    pass struct_ptr[0i64];
};

func:buf_get_u8 = int64(int64->:buf64, int64:offset) {
    int64:word = buf64[offset / 8i64];
    int64:shift = (offset & 7i64) * 8i64;
    pass (word >> shift) & 255i64;
};

func:buf_get_u64_be = uint64(int64->:buf64, int64:byte_off) {
    uint64:b0 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off));
    uint64:b1 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 1i64));
    uint64:b2 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 2i64));
    uint64:b3 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 3i64));
    uint64:b4 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 4i64));
    uint64:b5 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 5i64));
    uint64:b6 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 6i64));
    uint64:b7 = cast_unchecked<uint64>(raw buf_get_u8(buf64, byte_off + 7i64));
    pass (b0 << 56u64) | (b1 << 48u64) | (b2 << 40u64) | (b3 << 32u64) | (b4 << 24u64) | (b5 << 16u64) | (b6 << 8u64) | b7;
};

func:buf_set_u8 = int32(int64->:buf64, int64:byte_off, int64:val) {
    int64:wi = byte_off / 8i64;
    int64:shift = (byte_off & 7i64) * 8i64;
    int64:w = buf64[wi];
    int64:mask = ~(255i64 << shift);
    w = (w & mask) | ((val & 255i64) << shift);
    buf64[wi] = w;
    pass 0i32;
};

func:buf_set_u64_be = int32(int64->:buf64, int64:byte_off, uint64:val) {
    int64:v = cast_unchecked<int64>(val);
    drop raw buf_set_u8(buf64, byte_off, (v >> 56i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 1i64, (v >> 48i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 2i64, (v >> 40i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 3i64, (v >> 32i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 4i64, (v >> 24i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 5i64, (v >> 16i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 6i64, (v >> 8i64) & 255i64);
    drop raw buf_set_u8(buf64, byte_off + 7i64, v & 255i64);
    pass 0i32;
};

func:local_memcpy = int64(int64->:d, int64:dst_off, int64:src, int64:len) {
    int64->:s = cast_unchecked<int64->>(src);
    int64:i = 0i64;
    while (i < len) {
        int64:val = raw buf_get_u8(s, i);
        drop raw buf_set_u8(d, dst_off + i, val);
        i += 1i64;
    }
    pass 0i64;
};

func:local_memset = int64(int64->:d, int64:dst_off, int64:val, int64:len) {
    int64:i = 0i64;
    while (i < len) {
        drop raw buf_set_u8(d, dst_off + i, val);
        i += 1i64;
    }
    pass 0i64;
};

func:sha512_rotr = uint64(uint64:bits, uint64:word) {
    pass (word >> bits) | (word << (64u64 - bits));
};

func:sha512_ch = uint64(uint64:x, uint64:y, uint64:z) {
    pass (x & y) ^ ((~x) & z);
};

func:sha512_maj = uint64(uint64:x, uint64:y, uint64:z) {
    pass (x & y) ^ (x & z) ^ (y & z);
};

func:sha512_ep0 = uint64(uint64:x) {
    pass raw sha512_rotr(28u64, x) ^ raw sha512_rotr(34u64, x) ^ raw sha512_rotr(39u64, x);
};

func:sha512_ep1 = uint64(uint64:x) {
    pass raw sha512_rotr(14u64, x) ^ raw sha512_rotr(18u64, x) ^ raw sha512_rotr(41u64, x);
};

func:sha512_sig0 = uint64(uint64:x) {
    pass raw sha512_rotr(1u64, x) ^ raw sha512_rotr(8u64, x) ^ (x >> 7u64);
};

func:sha512_sig1 = uint64(uint64:x) {
    pass raw sha512_rotr(19u64, x) ^ raw sha512_rotr(61u64, x) ^ (x >> 6u64);
};

