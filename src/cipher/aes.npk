        }
        
        c = 0i64;
        while (c < 4i64) {
            c0_idx = c * 4i64 + 0i64;
            c1_idx = c * 4i64 + 1i64;
            c2_idx = c * 4i64 + 2i64;
            c3_idx = c * 4i64 + 3i64;
            
            v0 = (state_64[c0_idx / 8i64] >> ((c0_idx & 7i64) * 8i64)) & 255i64;
