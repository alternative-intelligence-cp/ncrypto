use "stdlib/core.npk".*;
use "src/util/hex.npk".*;
use "src/hash/blake2b.npk".*;

pub func:failsafe = int32(tbb32:err) { exit(1i32); };

func:buf_get_u8 = int64(int64->:buf64, int64:byte_off) {
    int64:wi = byte_off / 8i64;
    int64:sh = (byte_off & 7i64) * 8i64;
    int64:w = buf64[wi];
    pass (w >> sh) & 255i64;
};

func:buf_put_u8 = int32(int64->:buf64, int64:byte_off, int64:byte_val) {
    int64:wi = byte_off / 8i64;
    int64:sh = (byte_off & 7i64) * 8i64;
    int64:w = buf64[wi];
    int64:mask = ~(255i64 << sh);
    w = (w & mask) | ((byte_val & 255i64) << sh);
    buf64[wi] = w;
    pass 0i32;
};

func:test_blake2b_empty = int32() {
    int64:in_ptr = cast_unchecked<int64>(alloc(0i64));
    int64:out_ptr = cast_unchecked<int64>(alloc(64i64));
    
    drop raw blake2b_hash(in_ptr, 0i64, out_ptr, 64i64, 0i64, 0i64);
    
    int64:exp_ptr = cast_unchecked<int64>(alloc(64i64));
    drop raw hex_to_raw("786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce", exp_ptr);
    
    int64->:OUT = cast_unchecked<int64->>(out_ptr);
    int64->:EXP = cast_unchecked<int64->>(exp_ptr);
    
    int64:i = 0i64;
    while (i < 64i64) {
        if (raw buf_get_u8(OUT, i) != raw buf_get_u8(EXP, i)) { fail(1i32); }
        i += 1i64;
    }
    
    pass 0i32;
};

func:test_blake2b_abc = int32() {
    int64:in_ptr = cast_unchecked<int64>(alloc(3i64));
    int64->:IN = cast_unchecked<int64->>(in_ptr);
    drop raw buf_put_u8(IN, 0i64, 97i64);
    drop raw buf_put_u8(IN, 1i64, 98i64);
    drop raw buf_put_u8(IN, 2i64, 99i64);
    
    int64:out_ptr = cast_unchecked<int64>(alloc(64i64));
    
    drop raw blake2b_hash(in_ptr, 3i64, out_ptr, 64i64, 0i64, 0i64);
    
    int64:exp_ptr = cast_unchecked<int64>(alloc(64i64));
    drop raw hex_to_raw("ba80a53f981c4d0d6a2797b69f12f6e94c212f14685ac4b74b12bb6fdbffa2d17d87c5392aab792dc252d5de4533cc9518d38aa8dbf1925ab92386edd4009923", exp_ptr);
    
    int64->:OUT = cast_unchecked<int64->>(out_ptr);
    int64->:EXP = cast_unchecked<int64->>(exp_ptr);
    
    int64:i = 0i64;
    while (i < 64i64) {
        if (raw buf_get_u8(OUT, i) != raw buf_get_u8(EXP, i)) { fail(1i32); }
        i += 1i64;
    }
    
    pass 0i32;
};

pub func:main = int32() {
    int32:r1 = raw test_blake2b_empty();
    if (r1 != 0i32) { exit(1i32); }
    
    int32:r2 = raw test_blake2b_abc();
    if (r2 != 0i32) { exit(1i32); }
    
    drop sys!!(1i64, 1i64, "All Blake2b tests passed!\n", 26i64);
    exit(0i32);
};
